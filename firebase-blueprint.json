{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and membership data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "membershipStatus": { "type": "string", "enum": ["none", "active", "expired"] },
        "membershipExpiry": { "type": "string", "format": "date-time" },
        "membershipType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "membershipStatus"]
    },
    "Payment": {
      "title": "Payment Record",
      "description": "History of transactions via Paystack",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "reference": { "type": "string" },
        "status": { "type": "string" },
        "planId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and membership status"
    },
    "/users/{userId}/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Transaction history for each user"
    }
  }
}
