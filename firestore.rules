rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'josephakpansunday@gmail.com' || 
        request.auth.token.email == 'columnwallet@gmail.com'
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        isSuperAdmin() || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Default: deny everything
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── User Profiles ────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId)
        && (
          request.resource.data.membershipStatus == 'none'
          || request.resource.data.membershipStatus == 'inactive'
        );

      allow update: if 
        (isOwner(userId) 
          // Enforce that owners cannot change their own membership gating/roles
          && request.resource.data.membershipStatus == resource.data.membershipStatus
          && request.resource.data.membershipType  == resource.data.membershipType
          && request.resource.data.membershipExpiry == resource.data.membershipExpiry
          && (request.resource.data.role == resource.data.role || isSuperAdmin())
        ) || isAdmin();

      match /payments/{paymentId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }
    }

    // ─── Training Videos ─────────────────────────────────────
    match /training_videos/{videoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
